PORT=3000

# Omitir o cualquier valor salvo "false" = registro en un paso. "false" = codigo por email.
# SKIP_EMAIL_VERIFICATION=false

# Supabase: Dashboard > boton "Connect" (arriba).
# La conexion "Direct" (db.*.supabase.co:5432) es IPv6; en Windows/red IPv4 suele dar ENOTFOUND.
# Usa "Session pooler" (Shared pooler, IPv4): copia la URI tal cual del panel.
# Ejemplo de forma: postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# Resend: https://resend.com -> API Keys
# Para enviar a @udla.edu.co DEBES verificar un dominio en resend.com/domains y MAIL_FROM=noreply@tudominio.com
# onboarding@resend.dev solo permite enviar a la cuenta con la que te registraste en Resend (modo prueba).
RESEND_API_KEY=
MAIL_FROM=TesisAmazonia <noreply@TU_DOMINIO_VERIFICADO.com>

# Opcional: solo desarrollo local; en produccion prioriza RESEND_API_KEY
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=

# Secreto para firmar el JWT del registro (minimo 32 caracteres). Genera uno aleatorio y no lo compartas.
JWT_REGISTRATION_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria_de_al_menos_32_caracteres
