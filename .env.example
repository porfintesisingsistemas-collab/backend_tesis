PORT=3000

# Supabase: Dashboard > boton "Connect" (arriba).
# La conexion "Direct" (db.*.supabase.co:5432) es IPv6; en Windows/red IPv4 suele dar ENOTFOUND.
# Usa "Session pooler" (Shared pooler, IPv4): copia la URI tal cual del panel.
# Ejemplo de forma: postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# Gmail: contrasena de aplicacion (Google Cuenta > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=
# Opcional: remitente visible
MAIL_FROM=TesisAmazonia <tu_correo@gmail.com>

# Secreto para firmar el JWT del registro (minimo 32 caracteres). Genera uno aleatorio y no lo compartas.
JWT_REGISTRATION_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria_de_al_menos_32_caracteres
